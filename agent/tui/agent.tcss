Screen {
    background: #0f141a;
    color: #edf3ff;
}

#status {
    height: 3;
    dock: top;
    background: #151d26;
    color: #edf3ff;
    border: round #62d6e8;
    padding: 0 1;
    margin: 1 1 0 1;
}

#body {
    height: 1fr;
    margin: 1;
}

#main-column {
    width: 3fr;
    margin-right: 1;
}

#sidebar {
    width: 38;
}

StreamPanel,
PlanPanel,
ExecutionPanel,
LogsPanel,
TodoPanel,
VCSPanel,
CommandPanel {
    background: #131a22;
    border: round #425565;
    padding: 1;
    color: #edf3ff;
}

#stream {
    height: 2fr;
    border: round #62d6e8;
}

#plan {
    height: 9;
    border: round #f7c873;
    margin-top: 1;
}

#execution {
    height: 9;
    border: round #ffb454;
    margin-top: 1;
}

#logs {
    height: 1fr;
    border: round #7aa2f7;
    margin-top: 1;
}

#todo,
#vcs,
#commands {
    height: 1fr;
    margin-bottom: 1;
}

#todo {
    border: round #86efac;
}

#vcs {
    border: round #7aa2f7;
}

#commands {
    border: round #f7c873;
}

#command-input {
    dock: bottom;
    height: 3;
    margin: 0 1 1 1;
    border: round #f2c572;
    background: #151d26;
    color: #edf3ff;
}

Footer {
    background: #151d26;
    color: #edf3ff;
}
